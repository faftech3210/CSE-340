<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <% if (locals.errors) { %>
        <div class="alert error">
            <ul>
                <% errors.forEach(err => { %>
                    <li><%= err.msg %></li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <form action="/new-category" method="POST">
        <div class="form-group">
            <label for="name">Category Name</label>
            <input 
                type="text" 
                id="name" 
                name="name" 
                value="<%= formData.name %>" 
                maxlength="100" 
                required 
            />
        </div>
        <button type="submit">Save Category</button>
    </form>
</main>
<%- include('partials/footer') %>