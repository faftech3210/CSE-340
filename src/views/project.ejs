<%- include("./partials/header") %>

<h1><%= title %></h1>

<p><%= project.summary %></p>

<p>
    Organization:
    <a href="/organization/<%= organization.organization_id %>">
        <%= organization.name %>
    </a>
</p>

<h3>Categories</h3>

<div class="category-tags">
    <% categories.forEach(category => { %>
        <a
            class="category-tag"
            href="/categories/<%= category.category_id %>"
        >
            <%= category.name %>
        </a>
    <% }) %>
</div>
<a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>
<%- include("./partials/footer") %>