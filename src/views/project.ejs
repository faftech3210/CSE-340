<%- include("./partials/header") %>

<h1><%= title %></h1>
<hr>
<h3>Project Summary:</h3>

<p><strong>Project Title:</strong> <%= project.title %></p>
<p><strong>Project Description:</strong> <%= project.description %></p>

<p>📍 <strong>Location:</strong> <%= project.location %></p>
<p>📅 <strong>Date:</strong> <%= project.project_date %></p>
<p>
    Organization:
    <a href="/organization/<%= organization.organization_id %>">
        <%= organization.name %>
    </a>
</p>

<div class="edit-project">
    <% if (user && user.role_name === 'admin') { %>
        ✏️<a href="/edit-project/<%= project.project_id %>" class="btn">Edit Project</a>
    <% } %>
</div>
<div class="volunteer-section">
    <% if (typeof user !== 'undefined' && user) { %>
        <% if (isVolunteering) { %>
            <div class="alert alert-success">
                <p><strong>✓ You are volunteering for this project!</strong> Thank you for your commitment.</p>
                <form action="/projects/<%= project.project_id %>/unvolunteer" method="POST" class="cancel-volunteer-form">
                    <button type="submit" class="btn btn-danger btn-cancel-signup">
                        Cancel Volunteering Signup
                    </button>
                </form>
            </div>
        <% } else { %>
            <form action="/projects/<%= project.project_id %>/volunteer" method="POST" class="volunteer-form">
                <button type="submit" class="btn btn-primary btn-volunteer-action">
                    Volunteer for this Project
                </button>
            </form>
        <% } %>
    <% } else { %>
        <p class="text-muted"><em>Please <a href="/login">log in</a> to sign up as a volunteer for this service project.</em></p>
    <% } %>
</div>
<hr>
<h3>Categories</h3>

<div class="category-tags">
    <% categories.forEach(category => { %>
        <a
            class="category-tag"
            href="/categories/<%= category.category_id %>"
        >
            <%= category.name %>
        </a>
    <% }) %>
</div>

<div>
    <% if (user && user.role_name === 'admin') { %>
        ✏️<a href="/assign-categories/<%= project.project_id %>" class="btn">Edit Project Categories</a>
    <% } %>
</div>
<hr>

<%- include("./partials/footer") %>