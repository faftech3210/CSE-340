<%- include("./partials/header") %>

<h1><%= title %></h1>
<hr>
<h3>Project Summary:</h3>

<p><strong>Project Title:</strong> <%= project.title %></p>
<p><strong>Project Description:</strong> <%= project.description %></p>

<p>📍 <strong>Location:</strong> <%= project.location %></p>
<p>📅 <strong>Date:</strong> <%= project.project_date %></p>
<p>
    Organization:
    <a href="/organization/<%= organization.organization_id %>">
        <%= organization.name %>
    </a>
</p>

<div class="edit-project">
    <% if (user && user.role_name === 'admin') { %>
        ✏️<a href="/edit-project/<%= project.project_id %>" class="btn">Edit Project</a>
    <% } %>
</div>

<hr>
<h3>Categories</h3>

<div class="category-tags">
    <% categories.forEach(category => { %>
        <a
            class="category-tag"
            href="/categories/<%= category.category_id %>"
        >
            <%= category.name %>
        </a>
    <% }) %>
</div>

<div>
    <% if (user && user.role_name === 'admin') { %>
        ✏️<a href="/assign-categories/<%= project.project_id %>" class="btn">Edit Project Categories</a>
    <% } %>
</div>

<%- include("./partials/footer") %>