<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <% if (locals.messages && locals.messages.error) { %>
        <div class="alert error"><%= messages.error %></div>
    <% } %>

    <form action="/edit-project/<%= project.project_id %>" method="POST">
        <div class="form-group">
            <label for="title">Project Title</label>
            <input
                type="text"
                id="title"
                name="title"
                value="<%= project.title %>"
                maxlength="150"
                required
            />
        </div>

        <div class="form-group">
            <label for="description">Description</label>
            <textarea
                id="description"
                name="description"
                maxlength="500"
                required
            ><%= project.description %></textarea>
        </div>

        <div class="form-group">
            <label for="location">Location</label>
            <input
                type="text"
                id="location"
                name="location"
                value="<%= project.location %>"
                maxlength="255"
                required
            />
        </div>

        <div class="form-group">
            <label for="project_date">Date</label>
            <input
                type="date"
                id="project_date"
                name="project_date"
                value="<%= project.project_date ? new Date(project.project_date).toISOString().split('T')[0] : '' %>"
                required
            />
        </div>

        <div class="form-group">
            <label for="organizationId">Organization</label>
            <select id="organizationId" name="organizationId" required>
                <option value="">Select an organization</option>
                <% organizations.forEach(org => { %>
                    <option 
                        value="<%= org.organization_id %>" 
                        <%= org.organization_id === project.organization_id ? 'selected' : '' %>>
                        <%= org.name %>
                    </option>
                <% }); %>
            </select>
        </div>

        <button type="submit">Update Project Details</button>
    </form>
</main>
<%- include('partials/footer') %>